# Copy this file to docker.env and replace every change-me value.
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-use-a-long-random-secret
DEBUG=False

POSTGRES_DB=besat_site
POSTGRES_USER=besat_user
POSTGRES_PASSWORD=change-me-database-password
DATABASE_URL=postgres://besat_user:change-me-database-password@db:5432/besat_site

ALLOWED_HOSTS=localhost,127.0.0.1,backend,your-domain.example
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.example
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-domain.example

SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

ADMIN_URL=admin/
ENABLE_API_DOCS=False
TIME_ZONE=Asia/Tehran
LANGUAGE_CODE=fa-ir

BACKEND_PORT=8000
PORT=8000
WEB_CONCURRENCY=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
WAIT_FOR_DATABASE=1
DATABASE_WAIT_MAX_ATTEMPTS=30
DATABASE_WAIT_DELAY_SECONDS=2
RUN_MIGRATIONS=1
COLLECT_STATIC=1
